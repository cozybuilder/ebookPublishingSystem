node_modules
.env
.DS_Store
*.log

# 테스트 전용 산출물(실제 output/ 와 분리) — 추적하지 않는다
tmp/

# 생성 가능한 PNG/PDF/DOCX/EPUB 산출물(export 로 재생성) — 추적하지 않는다
output/*.png
output/*.pdf
output/*.docx
output/*.epub

# 챕터별 상세 캔버스(별도 선택 산출물, 챕터 수에 따라 가변) — 추적하지 않는다
output/canvas.chapter*.html

# Preview Promo(SNS) 캔버스 HTML(마케팅 보조) — 추적하지 않는다
output/book.preview.square.html
output/book.preview.story.html

# 이미지 프롬프트 매니페스트(재생성 가능) — 추적하지 않는다
output/image-prompts.json
output/image-prompts.md

# Front Matter 매니페스트(재생성 가능) — 추적하지 않는다
output/front-matter.json
output/front-matter.md

# output 폴더는 현재 검증용 산출물(book.ast.json 등)을 추적하기 위해
# 의도적으로 제외하지 않는다. (이후 단계에서 정책 재검토)
